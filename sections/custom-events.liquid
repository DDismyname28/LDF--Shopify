<section class="custom-events-feature">
  <div class="custom-events-feature__inner">

    {% assign blog = section.settings.blog %}
    {% assign featured_article = blog.articles.first %}

    <!-- LEFT: FEATURED -->
    <div class="custom-events-feature__main">
      {% if featured_article != blank %}
        <a href="{{ featured_article.url }}" class="custom-events-feature__main-image">
          {% if featured_article.image != blank %}
            {{ featured_article.image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
          {% else %}
            <span>Featured Project / Event Image</span>
          {% endif %}
        </a>

        <h2>{{ featured_article.title }}</h2>

        <p class="custom-events-feature__date">
        {% if featured_article.metafields.custom.event_date != blank %}
            {{ featured_article.metafields.custom.event_date | date: "%b %d, %Y" }}
        {% endif %}
        </p>

        <p>
        {% if featured_article.excerpt != blank %}
            {{ featured_article.excerpt | strip_html | truncate: 90 }}
        {% else %}
            {{ featured_article.content | strip_html | truncate: 90 }}
        {% endif %}
        </p>
      {% else %}
        <div class="custom-events-feature__main-image">
          <span>Featured Project / Event Image</span>
        </div>

        <h2>Event or Project Feature</h2>
        <p>Short description — link to full post or gallery</p>
      {% endif %}
    </div>

    <!-- RIGHT: LIST -->
    <div class="custom-events-feature__list">
      {% if blog != blank %}
        {% for article in blog.articles offset: 1 limit: 3 %}
          <article class="custom-events-feature__card">
            <h3>{{ article.title }}</h3>

            <p class="custom-events-feature__date">
            {% if article.metafields.custom.event_date != blank %}
                {{ article.metafields.custom.event_date | date: "%b %d, %Y" }}
            {% endif %}
            </p>

            <a href="{{ article.url }}">Learn more →</a>
          </article>
        {% endfor %}
      {% else %}
        {% for i in (1..3) %}
          <article class="custom-events-feature__card">
            <h3>Upcoming Event</h3>
            <p>Date · Location</p>
            <a href="#">Learn more →</a>
          </article>
        {% endfor %}
      {% endif %}
    </div>

  </div>
</section>

<style>
  .custom-events-feature {
    background: var(--cream);
    padding: 0px 10px;
  }

  .custom-events-feature__inner {
    max-width: 1280px;
    margin: 0 auto;
    background: var(--cream);

    padding: 28px;

    display: grid;
    grid-template-columns: 1.75fr 1fr;
    gap: 28px;
  }

  /* LEFT FEATURE */
  .custom-events-feature__main-image {
    width: 100%;
    height: 365px;
    border-radius: 4px;
    background: #d8d5ce;

    display: flex;
    align-items: center;
    justify-content: center;

    overflow: hidden;
    text-decoration: none;
    color: rgba(46, 61, 52, 0.45);
    font-size: 13px;
  }

  .custom-events-feature__main-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .custom-events-feature__main h2 {
    margin: 10px 0 4px;
    color: #1d1d1d;
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: var(--font-weight-bold);
  }

  .custom-events-feature__main p {
    margin: 0;
    color: rgba(46, 61, 52, 0.55);
    font-family: var(--font-body);
    font-size: 14px;
  }

  /* RIGHT LIST */
  .custom-events-feature__list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .custom-events-feature__card {
    background: #fff;
    border: 1px solid #d7d1c8;
    border-radius: 4px;
    padding: 20px 22px;
  }

  .custom-events-feature__card h3 {
    margin: 0 0 6px;
    color: #1d1d1d;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: var(--font-weight-bold);
  }

  .custom-events-feature__card p {
    margin: 0 0 10px;
    color: rgba(46, 61, 52, 0.6);
    font-family: var(--font-body);
    font-size: 14px;
  }

  .custom-events-feature__card a {
    color: var(--crimson);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: var(--font-weight-bold);
    text-decoration: none;
  }

  @media screen and (max-width: 900px) {
    .custom-events-feature__inner {
      grid-template-columns: 1fr;
      padding: 20px;
    }

    .custom-events-feature__main-image {
      height: 260px;
    }
  }
</style>

{% schema %}
{
  "name": "Custom events feature",
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "Events blog"
    }
  ],
  "presets": [
    {
      "name": "Custom events feature"
    }
  ]
}
{% endschema %}