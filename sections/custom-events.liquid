<section class="custom-events-feature">
  <div class="custom-events-feature__inner">
    {% assign blog = section.settings.blog %}

    <div class="custom-events-feature__main">
      {% if section.settings.feature_image != blank %}
        {{ section.settings.feature_image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
      {% else %}
        <span>Featured Project / Event Image</span>
      {% endif %}

      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>
    </div>

    <div class="custom-events-feature__list">
      {% if blog != blank %}
        {% for article in blog.articles limit: 3 %}
          <article class="custom-events-feature__card">
            <h3>{{ article.title }}</h3>

            <p>
              {% if article.metafields.custom.event_date != blank %}
                {{ article.metafields.custom.event_date }}
              {% else %}
                {{ article.published_at | date: "%b %d, %Y" }}
              {% endif %}

              {% if article.metafields.custom.location != blank %}
                · {{ article.metafields.custom.location }}
              {% endif %}
            </p>

            <a href="{{ article.url }}">Learn more →</a>
          </article>
        {% endfor %}
      {% else %}
        {% for i in (1..3) %}
          <article class="custom-events-feature__card">
            <h3>Upcoming Event</h3>
            <p>Date · Location</p>
            <a href="#">Learn more →</a>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

<style>
  .custom-events-feature {
    background: #f8f6f2;
    padding: 8px 10px;
  }

  .custom-events-feature__inner {
    max-width: 1280px;
    margin: 0 auto;
    background: var(--cream);
    border: 1px solid #d7d1c8;
    border-radius: 4px;
    padding: 28px;
    display: grid;
    grid-template-columns: 1.75fr 1fr;
    gap: 28px;
  }

  .custom-events-feature__main img,
  .custom-events-feature__main > span {
    width: 100%;
    height: 365px;
    border-radius: 4px;
    background: #d8d5ce;
    display: flex;
    align-items: center;
    justify-content: center;
    object-fit: cover;
    color: rgba(46, 61, 52, 0.45);
    font-size: 13px;
  }

  .custom-events-feature__main h2 {
    margin: 8px 0 4px;
    color: #1d1d1d;
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: var(--font-weight-bold);
  }

  .custom-events-feature__main p {
    margin: 0;
    color: rgba(46, 61, 52, 0.55);
    font-family: var(--font-body);
    font-size: 14px;
  }

  .custom-events-feature__list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .custom-events-feature__card {
    background: #fff;
    border: 1px solid #d7d1c8;
    border-radius: 4px;
    padding: 22px 24px;
  }

  .custom-events-feature__card h3 {
    margin: 0 0 6px;
    color: #1d1d1d;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: var(--font-weight-bold);
  }

  .custom-events-feature__card p {
    margin: 0 0 10px;
    color: rgba(46, 61, 52, 0.6);
    font-family: var(--font-body);
    font-size: 14px;
  }

  .custom-events-feature__card a {
    color: var(--crimson);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: var(--font-weight-bold);
    text-decoration: none;
  }

  @media screen and (max-width: 900px) {
    .custom-events-feature__inner {
      grid-template-columns: 1fr;
      padding: 20px;
    }

    .custom-events-feature__main img,
    .custom-events-feature__main > span {
      height: 260px;
    }
  }
</style>

{% schema %}
{
  "name": "Custom events feature",
  "settings": [
    {
      "type": "image_picker",
      "id": "feature_image",
      "label": "Featured image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Featured heading",
      "default": "Event or Project Feature"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Featured description",
      "default": "Short description — link to full post or gallery"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Events blog"
    }
  ],
  "presets": [
    {
      "name": "Custom events feature"
    }
  ]
}
{% endschema %}