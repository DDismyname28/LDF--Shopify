<div class="breadcrumb-sku-wrapper">
  <!-- LEFT SIDE -->
  <div class="breadcrumb-left">
    <a href="/">Shop</a>

    <span class="divider">›</span>

    {% if product.collections.first %}
      <a href="{{ product.collections.first.url }}">
        {{ product.collections.first.title }}
      </a>
    {% else %}
      <span>Categories</span>
    {% endif %}

    <span class="divider">›</span>

    <span class="product-title">
      {{ product.title }}
    </span>
  </div>

  <!-- RIGHT SIDE -->
  <div class="breadcrumb-right">
    <span class="sku-label">SKU:</span>
    <span class="sku-value">
      {{ product.selected_or_first_available_variant.sku }}
    </span>
  </div>
</div>

<style>
  .breadcrumb-sku-wrapper {
    max-width: 1280px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-body);
    font-size: 12px;
    margin-bottom: 20px;
    padding: 10px 40px;
    border: 1px solid #c8c2b8;
    background-color: var(--cream);
    border-radius: 4px;
    margin: 0 auto;
  }
  .breadcrumb-left a {
    color: #978c7b;
    text-decoration: none;
  }
  .breadcrumb-left .product-title {
    color: var(--navy);
    font-weight: var(--font-weight-bold);
    font-size: 12px;
  }
  .breadcrumb-left .divider {
    margin: 0 5px;
    color: #999;
  }
  .breadcrumb-right {
    display: flex;
    align-items: center;
  }
  .sku-label,
  .sku-value {
    font-weight: var(--font-weight-regular);
    color: #978c7b;
  }
  .sku-label {
    margin-right: 5px;
  }

  /* Desktop (1025px and up) */
  @media (min-width: 1025px) {
    #shopify-section-template--26708638925105__product_breadcrumb_sku {
      max-width: var(--page-width);
      margin: 0 auto;
      padding: 40px;
    }
  }

  /* Tablet (768px - 1024px) */
  @media (min-width: 768px) and (max-width: 1024px) {
    .breadcrumb-sku-wrapper {
      max-width: var(--page-width);
      margin: 0 15px;
    }
  }

  /* Mobile (0 - 767px) */
  @media (max-width: 767px) {
    .breadcrumb-sku-wrapper {
      flex-wrap: wrap;
      max-width: var(--page-width);
      margin: 0 15px;
    }
  }
</style>
