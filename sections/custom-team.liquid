<section class="team-section">
  <div class="team-section__inner">
    {% for block in section.blocks %}
      <div class="team-section__row" {{ block.shopify_attributes }}>
        <div class="team-section__image">
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy' }}
          {% else %}
            <div class="team-section__placeholder">
              Team Member
              <span>Full portrait photo</span>
            </div>
          {% endif %}

          <div class="team-section__overlay">
            <h3>{{ block.settings.name }}</h3>
            <span>{{ block.settings.role }}</span>
          </div>
        </div>

        <div class="team-section__content">
          <span class="team-section__eyebrow">{{ section.settings.eyebrow }}</span>

          <blockquote>
            “{{ block.settings.quote }}”
          </blockquote>

          <p>{{ block.settings.description }}</p>

<div class="team-section__cta">
  {% if block.settings.link != blank %}
    <a href="{{ block.settings.link }}" class="team-section__button">
      {{ section.settings.button_text }}
    </a>
  {% endif %}

  {% if section.settings.secondary_button_link != blank %}
    <a href="{{ section.settings.secondary_button_link }}" class="team-section__button team-section__button--secondary">
      {{ section.settings.secondary_button_text }}
    </a>
  {% endif %}
</div>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

<style>
  .team-section {
  background: #fff;
  padding:20px 10px;
  font-family: var(--font-body);
}

.team-section__inner {
  max-width: 1280px;
  margin: 0 auto;
}

.team-section__row {
  display: grid;
  grid-template-columns: 1fr 1.13fr;
  min-height: 465px;
  background: #fff;
  overflow: hidden;

}

.team-section__image {
  position: relative;
  min-height: 465px;
  background: #d2cec6;
}

.team-section__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.team-section__placeholder {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #8c857a;
  font-size: 13px;
  text-align: center;
}

.team-section__placeholder span {
  margin-top: 4px;
  font-size: 11px;
}

.team-section__overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 34px 40px;
  color: #fff;
  background: linear-gradient(to top, rgba(178, 31, 36, 0.95), rgba(178, 31, 36, 0));
}

.team-section__overlay h3 {
  margin: 0 0 8px;
  font-size: 26px;
  line-height: 1;
  font-weight: 700;
  color: #ffffff;
  font-family: var(--font-body);
}

.team-section__overlay span {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  font-family: var(--font-body);
}

.team-section__content {
  padding: 78px 50px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.team-section__eyebrow {
  margin-bottom: 34px;
  color: #8a8177;
  font-size: 15px;
  font-weight: 700;
  text-transform: uppercase;
  font-family: var(--font-body);
}

.team-section__content blockquote {
  max-width: 440px;
  margin: 0 0 28px;
  padding-left: 22px;
  border-left: 3px solid var(--crimson);
  color: #1f3155;
  font-size: 24px;
  line-height: 1.2;
  font-style: italic;
  font-family: var(--font-body);
}

.team-section__content p {
  max-width: 470px;
  margin: 0 0 34px;
  color: #4f4f4f;
  font-size: 19px;
  line-height: 1.5;
  font-family: var(--font-body);
}

.team-section__cta {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
}

.team-section__button {
  min-width: 210px;
  height: 42px;
  background: var(--crimson);
  color: var(--cream);
  border-radius: 3px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  font-size: 13px;
  font-weight: 700;
  font-family: var(--font-body);
}

.team-section__button:hover {
      color: #E8F9FF !important;

}

.team-section__cta span {
  color: #8a8177;
  font-size: 11px;
  font-style: italic;
  font-family: var(--font-body);
}

@media screen and (max-width: 800px) {
  .team-section__row {
    grid-template-columns: 1fr;
  }

  .team-section__image {
    min-height: 340px;
  }

  .team-section__content {
    padding: 38px 24px;
  }

  .team-section__cta {
    align-items: flex-start;
    flex-direction: column;
  }

  .team-section__button {
    width: 100%;
  }
}
</style>

{% schema %}
{
  "name": "Meet the team",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "THE PEOPLE BEHIND THE PRODUCTS"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "READ THEIR STORY →"
    },
    {
    "type": "text",
    "id": "secondary_button_text",
    "label": "Secondary button text",
    "default": "READ THEIR STORY→"
    },
    {
    "type": "url",
    "id": "secondary_button_link",
    "label": "Secondary button link"
    }
  ],
  "blocks": [
    {
      "type": "member",
      "name": "Team member",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Team Member Name"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role / title",
          "default": "ROLE / TITLE"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Short quote from the team member — something real, personal, and on-brand about why they love what they do."
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "2–3 sentence bio. What they do at LED, their background, what makes them great at it. Written in brand voice — warm, real, no corporate fluff."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Story link"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Meet the team",
      "blocks": [
        {
          "type": "member"
        }
      ]
    }
  ]
}
{% endschema %}