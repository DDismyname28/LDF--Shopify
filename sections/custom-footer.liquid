<footer class="custom-footer">
  <div class="custom-footer__inner">

    <!-- BRAND -->
    <div class="custom-footer__brand">
      <a href="{{ routes.root_url }}" class="custom-footer__logo">
        {% if section.settings.logo != blank %}
          {{ section.settings.logo | image_url: width: 180 | image_tag: loading: 'lazy', alt: shop.name }}
        {% else %}
          LOGO
        {% endif %}
      </a>
{% comment %} 
      <p>{{ section.settings.tagline }}</p> {% endcomment %}
    </div>

    <!-- SHOP -->
    <div class="custom-footer__menu">
      <h3>SHOP</h3>
      <a href="/collections/all">All Products</a>
      <a href="/collections">Collections</a>
      <a href="/blogs/events">Events</a>
      <a href="/collections/new-arrivals">New Arrivals</a>
    </div>

    <!-- TRADE -->
    <div class="custom-footer__menu">
      <h3>TRADE</h3>
      <a href="/pages/apply-for-account">Apply for Account</a>
      <a href="{{ routes.account_login_url }}">Trade Login</a>
      <a href="/pages/faqs">FAQs</a>
      <a href="/pages/contact">Contact</a>
    </div>

    <!-- CONNECT -->
    <div class="custom-footer__menu">
      <h3>CONNECT</h3>
      <a href="#newsletter">Email Signup</a>
      <a href="https://instagram.com" target="_blank">Instagram</a>
      <a href="https://facebook.com" target="_blank">Facebook</a>
    </div>

    <!-- NEWSLETTER -->
    <div class="custom-footer__newsletter" id="newsletter">
      {% form 'customer' %}
        <input type="hidden" name="contact[tags]" value="newsletter">

        <input
          type="email"
          name="contact[email]"
          placeholder="Enter your email"
          required
        >

        <button type="submit">
          {{ section.settings.button_text }}
        </button>
      {% endform %}
    </div>

    <!-- BOTTOM -->
    <div class="custom-footer__bottom">
      <p>
        © {{ 'now' | date: '%Y' }} {{ shop.name }}
        · <a href="/policies/privacy-policy">Privacy Policy</a>
        · <a href="/policies/terms-of-service">Terms of Service</a>
      </p>
    </div>

  </div>
</footer>

<style>
  .custom-footer {
    background: var(--navy);
    padding: 0px 10px;
  }

  .custom-footer__inner {
    max-width: 1280px;
    margin: 0 auto;
    background: var(--navy);

    padding: 40px;
    color: rgba(255,255,255,0.6);

    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr 1fr 1.4fr;
    gap: 48px;
  }

  /* BRAND */
  .custom-footer__logo {
    width: 150px;
    height: 50px;

    color: #fff;
    border-radius: 3px;

    display: flex;
    align-items: center;
    justify-content: center;

    font-weight: var(--font-weight-bold);
    text-decoration: none;
  }

  .custom-footer__logo img {
    max-width: 100%;
    max-height: 100%;
  }

  .custom-footer__brand p {
    margin: 8px 0 0;
    font-size: 14px;
  }

  /* MENUS */
  .custom-footer__menu h3 {
    margin: 0 0 14px;
    color: rgba(255,255,255,0.5);
    font-size: 12px;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

.custom-footer__menu a {
  display: block;
  margin-bottom: 6px; 
  color: rgba(255,255,255,0.6);
  text-decoration: none;
  font-size: 14px;
  line-height: 1.2;
}

  .custom-footer__menu a:hover {
    color: #fff;
  }

  /* NEWSLETTER */
  .custom-footer__newsletter form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .custom-footer__newsletter input {
    height: 48px;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 4px;
    background: rgba(255,255,255,0.08);
    color: #fff;
    padding: 0 16px;
  }

  .custom-footer__newsletter input::placeholder {
    color: rgba(255,255,255,0.45);
  }

  .custom-footer__newsletter button {
    height: 44px;
    background: var(--crimson);
    color: #fff;
    border: none;
    border-radius: 3px;
    font-weight: var(--font-weight-bold);
    cursor: pointer;
  }

  /* BOTTOM */
  .custom-footer__bottom {
    grid-column: 1 / -1;
    border-top: 1px solid rgba(255,255,255,0.15);
    margin-top: 20px;
    padding-top: 16px;
    text-align: center;
  }

  .custom-footer__bottom p,
  .custom-footer__bottom a {
    color: rgba(255,255,255,0.45);
    font-size: 13px;
    text-decoration: none;
  }

  @media (max-width: 1000px) {
    .custom-footer__inner {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
  }

  @media (max-width: 600px) {
    .custom-footer__inner {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Custom footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "|"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Subscribe button text",
      "default": "SUBSCRIBE"
    }
  ],
  "presets": [
    {
      "name": "Custom footer"
    }
  ]
}
{% endschema %}