{% if section.settings.event %}
  {% assign event = section.settings.event %}
  <section class="next-up-event">
    <div class="event-wrapper">
      <div class="event-image">
        {% if event.tag != blank %}
          <span class="event-tag">{{ event.tag }}</span>
        {% endif %}
        {% if event.image != blank %}
          <img src="{{ event.image | image_url: width: 600 }}" alt="{{ event.title }}">
        {% endif %}
      </div>
      <div class="event-details">
        <h4 class="next-up">NEXT UP</h4>
        <h2 class="event-title">{{ event.title }}</h2>
        <p class="event-meta">📅 {{ event.date }} · 📍 {{ event.location }} · ⏰ {{ event.time }}</p>
        <p class="event-description">{{ event.description }}</p>
        {% if event.link != blank %}
          <a href="{{ event.link }}" class="register-btn">REGISTER NOW ➜</a>
        {% endif %}
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Next Up Event",
  "settings": [
    {
      "type": "metaobject",
      "id": "event",
      "label": "Select Event",
      "metaobject_type": "event"
    }
  ],
  "presets": [
    {
      "name": "Next Up Event",
      "category": "Events"
    }
  ]
}
{% endschema %}
