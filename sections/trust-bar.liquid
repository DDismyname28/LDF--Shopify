<section class="custom-feature-bar">
  <div class="custom-feature-bar__inner">
    {% for block in section.blocks %}
      <div class="custom-feature-bar__item" {{ block.shopify_attributes }}>
        
        <div
          class="custom-feature-bar__icon"
          style="
            --icon-color: {{ block.settings.icon_color }};
            --icon-bg-color: {{ block.settings.icon_bg_color }};
            {% if block.settings.icon != blank %}
              --icon-url: url('{{ block.settings.icon | image_url: width: 160 }}');
            {% endif %}
          "
        >
          {% if block.settings.icon != blank %}
            <span class="custom-feature-bar__masked-icon"></span>
          {% else %}
            ICON
          {% endif %}
        </div>

        <h3>{{ block.settings.title }}</h3>
        <p>{{ block.settings.text }}</p>
      </div>
    {% endfor %}
  </div>
</section>

<style>
.custom-feature-bar {
  background: #fff;
  padding: 20px 10px;
}

.custom-feature-bar__inner {
  max-width: 1280px;
  margin: 0 auto;
  min-height: 98px;

  background: #fff;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  align-items: center;
}

.custom-feature-bar__item {
  position: relative;
  text-align: center;
  padding: 14px 24px 16px;
}

.custom-feature-bar__item:not(:last-child)::after {
  content: "";
  position: absolute;
  right: 0;
  top: 14px;
  bottom: 20px;
  width: 1px;
  background: #d9d2c7;
}

.custom-feature-bar__icon {
  width: 72px;
  height: 72px;
  margin: 0 auto 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--icon-bg-color, #ffffff);
  border-radius: 50%;
}

.custom-feature-bar__masked-icon {
  width: 36px;
  height: 36px;
  display: block;
  background: var(--icon-color, #1d1d1d);
  -webkit-mask-image: var(--icon-url);
  mask-image: var(--icon-url);
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-position: center;
  mask-position: center;
  -webkit-mask-size: contain;
  mask-size: contain;
}

.custom-feature-bar__item h3 {
  margin: 0 0 4px;
  color: #1d1d1d;
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: var(--font-weight-bold);
  line-height: 1.1;
}

.custom-feature-bar__item p {
  margin: 0;
  color: rgba(46, 61, 52, 0.55);
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: var(--font-weight-regular);
  line-height: 1.2;
}

@media screen and (max-width: 900px) {
  .custom-feature-bar__inner {
    grid-template-columns: repeat(2, 1fr);
  }

  .custom-feature-bar__item:nth-child(2)::after {
    display: none;
  }
}

@media screen and (max-width: 560px) {
  .custom-feature-bar__inner {
    grid-template-columns: 1fr;
  }

  .custom-feature-bar__item::after {
    display: none;
  }

  .custom-feature-bar__item {
    border-bottom: 1px solid #d9d2c7;
  }

  .custom-feature-bar__item:last-child {
    border-bottom: 0;
  }
}
</style>

{% schema %}
{
  "name": "Custom feature bar",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "color",
          "id": "icon_color",
          "label": "Icon color",
          "default": "#1d1d1d"
        },
        {
          "type": "color",
          "id": "icon_bg_color",
          "label": "Icon circle background",
          "default": "#ffffff"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Trade Pricing"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Login for wholesale rates"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom feature bar",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Trade Pricing",
            "text": "Login for wholesale rates"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Bulk Orders Welcome",
            "text": "Volume discounts available"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Expert Support",
            "text": "Decorators helping decorators"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Fast Shipping",
            "text": "Ships within 48hrs"
          }
        }
      ]
    }
  ]
}
{% endschema %}