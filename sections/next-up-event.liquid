<!-- SECTION 1: Hero -->

<section class="events-wrapper next-up-event-hero">
  <div class="section-header">
    <span class="section-subtitle">Find Us in the Field</span>
    <h1 class="section-title">Events + Training</h1>
    <p class="section-description">
      Trade shows, hands-on trainings, workshops, and seasonal markets
    </p>
    <p class="section-description">
      — find us near you and register to attend.
    </p>
  </div>

{% assign events = shop.metaobjects.events_and_trainings.values | sort: 'event_date.value' | reverse %}

{% assign latest_event = events | first %}

{% if latest_event != blank %}
  <section class="events-section featured-section">
    
    <span class="next-up-label">NEXT UP</span>
    <div class="featured-event-wrapper">
      <div class="featured-event-image">
        {% if latest_event.category.value != blank %}
          <span class="featured-event-tag">{{ latest_event.category.value }}</span>
        {% endif %}

        {% if latest_event.featured_image.value != blank %}
          <img
            src="{{ latest_event.featured_image.value | image_url: width: 900 }}"
            alt="{{ latest_event.title.value }}"
          >
        {% endif %}
      </div>

      <div class="featured-event-details">
        <h3 class="featured-event-title">{{ latest_event.title.value }}</h3>
        <p class="featured-event-meta">

  <!-- DATE -->
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/>
  </svg>

  {{ latest_event.event_date.value | date: "%B %d, %Y" }}


  <!-- LOCATION -->
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pinned-icon lucide-map-pinned"><path d="M18 8c0 3.613-3.869 7.429-5.393 8.795a1 1 0 0 1-1.214 0C9.87 15.429 6 11.613 6 8a6 6 0 0 1 12 0"/><circle cx="12" cy="8" r="2"/><path d="M8.714 14h-3.71a1 1 0 0 0-.948.683l-2.004 6A1 1 0 0 0 3 22h18a1 1 0 0 0 .948-1.316l-2-6a1 1 0 0 0-.949-.684h-3.712"/></svg>

  {{ latest_event.location.value }}


  <!-- TIME (converted to 12-hour format) -->
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="13" r="8"/><path d="M12 9v4l2 2"/>
  </svg>

  {% assign time_parts = latest_event.time.value | split: ':' %}
  {% assign hour = time_parts[0] | plus: 0 %}
  {% assign minute = time_parts[1] %}

  {% if hour == 0 %}
    {% assign display_hour = 12 %}
    {% assign period = "AM" %}
  {% elsif hour < 12 %}
    {% assign display_hour = hour %}
    {% assign period = "AM" %}
  {% elsif hour == 12 %}
    {% assign display_hour = 12 %}
    {% assign period = "PM" %}
  {% else %}
    {% assign display_hour = hour | minus: 12 %}
    {% assign period = "PM" %}
  {% endif %}

  {{ display_hour }}:{{ minute }} {{ period }}

</p>

        <p class="featured-event-description">
          {{ latest_event.description.value }}
        </p>

        {% if latest_event.registration_url.value != blank %}
          <button href="{{ latest_event.registration_url.value }}" class="featured-register-btn"> REGISTER NOW <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="lucide lucide-move-right-icon lucide-move-right"
              >
                <path d="M18 8L22 12L18 16"/><path d="M2 12H22"/>
              </svg> </button>
        {% endif %}
      </div>
    </div>
  </section>
{% endif %}



{% assign events = shop.metaobjects.events_and_trainings.values %}
{% assign today_timestamp = 'now' | date: '%s' %}

{% assign month_names = 'January,February,March,April,May,June,July,August,September,October,November,December' | split: ',' %}

{% if events != blank %}

<section class="events-tab events-section">

  <!-- MAIN TABS -->
  <div class="event-tabs">
    <button class="event-tab-btn active" data-tab="upcoming">
      Upcoming Events
    </button>

    <button class="event-tab-btn" data-tab="past">
      Past Events
    </button>
  </div>

  <!-- FILTERS -->
  <div class="event-filters">

    <p class="filter-label">Filter by Type</p>
    <div class="filter-group">

      <button class="filter-btn active" data-category="all">
        All Categories
      </button>

      {% assign categories = '' %}

      {% for event in events %}
        {% assign category = event.category.value %}

        {% unless categories contains category %}
          {% assign categories = categories | append: category | append: ',' %}

          <button
            class="filter-btn"
            data-category="{{ category | handleize }}"
          >
            {{ category }}
          </button>
        {% endunless %}
      {% endfor %}

    </div>

    <p class="filter-label">Filter by Month</p>
    <div class="filter-group">

      <button class="month-btn active" data-month="all">
        All Months
      </button>

      {% for month_name in month_names %}

        {% assign month_exists = false %}

        {% for event in events %}
          {% assign event_month = event.event_date.value | date: '%B' %}

          {% if event_month == month_name %}
            {% assign month_exists = true %}
          {% endif %}
        {% endfor %}

        {% if month_exists %}
          <button
            class="month-btn"
            data-month="{{ month_name | downcase }}"
          >
            {{ month_name }}
          </button>
        {% endif %}

      {% endfor %}

    </div>

  </div>

  <!-- COUNTER -->
  <div class="events-count-wrapper">
    <span class="events-count-text">
      Showing
      <span id="events-count">0</span>
      <span id="events-status-label">upcoming</span>
      events in
      <span id="events-year">{{ 'now' | date: '%Y' }}</span>
    </span>
  </div>

  <!-- EMPTY STATE -->
  <div class="no-events-message" style="display:none;">
    No events found for this filter.
  </div>

  <!-- EVENTS LIST -->
  <section class="event-lists-section">

    {% for event in events %}

      {% assign category = event.category.value | handleize %}
      {% assign month = event.event_date.value | date: '%B' | downcase %}
      {% assign event_date_raw = event.event_date.value %}

      {% assign event_timestamp = event_date_raw | date: '%s' %}

      {% if event_date_raw != blank and event_timestamp >= today_timestamp %}
        {% assign event_status = 'upcoming' %}
      {% else %}
        {% assign event_status = 'past' %}
      {% endif %}

      <div
        class="event-wrapper"
        data-category="{{ category }}"
        data-month="{{ month }}"
        data-status="{{ event_status }}"
      >

        <!-- DATE BOX -->
        <div class="event-date-box">
          <span class="event-month">
            {{ event.event_date.value | date: '%b' }}
          </span>

          <span class="event-day">
            {{ event.event_date.value | date: '%d' }}
          </span>
        </div>

        <!-- CONTENT -->
        <div class="event-content">

          {% if event.category.value != blank %}

            {% assign category_handle = event.category.value | handleize %}

            <p class="event-category
              {% case category_handle %}
                {% when 'training' %}category-training
                {% when 'trade-show' %}category-trade-show
                {% when 'workshop' %}category-workshop
                {% when 'seasonal-market' %}category-seasonal
                {% when 'industry' %}category-seasonal
              {% endcase %}
            ">
              {{ event.category.value }}
            </p>

          {% endif %}

          <p class="event-location-time">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 8c0 3.613-3.869 7.429-5.393 8.795a1 1 0 0 1-1.214 0C9.87 15.429 6 11.613 6 8a6 6 0 0 1 12 0"/>
              <circle cx="12" cy="8" r="2"/>
              <path d="M8.714 14h-3.71a1 1 0 0 0-.948.683l-2.004 6A1 1 0 0 0 3 22h18a1 1 0 0 0 .948-1.316l-2-6a1 1 0 0 0-.949-.684h-3.712"/>
            </svg>

            {{ event.location.value }}

            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="13" r="8"/>
              <path d="M12 9v4l2 2"/>
            </svg>

            {{ event.event_date.value | date: '%I:%M %p' }}
          </p>

          <p class="event-description">
            {{ event.description.value }}
          </p>

          {% if event.registration_url.value != blank %}
            <a href="{{ event.registration_url.value }}" class="event-register-link">
              RSVP / Register
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 8L22 12L18 16"/>
                <path d="M2 12H22"/>
              </svg>
            </a>
          {% endif %}

        </div>
      </div>

    {% endfor %}

  </section>
    <div class="load-more-wrapper" style="text-align:center; margin: 20px 0;">
      <button id="load-more-btn" class="load-more-btn">
        Load More Events
      </button>
    </div>
</section>

{% endif %}


