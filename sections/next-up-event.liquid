<script>
document.addEventListener('DOMContentLoaded', function () {

  let activeCategory = 'all';
  let activeMonth = 'all';
  let activeStatus = 'upcoming';

  // 👇 LOAD MORE SETTINGS
  let visibleLimit = 2;
  const increment = 5;

  const eventCards = document.querySelectorAll('.event-wrapper');

  const categoryButtons = document.querySelectorAll('.filter-btn');
  const monthButtons = document.querySelectorAll('.month-btn');
  const tabButtons = document.querySelectorAll('.event-tab-btn');

  const noEventsMessage = document.querySelector('.no-events-message');

  const eventsCount = document.getElementById('events-count');
  const eventsStatusLabel = document.getElementById('events-status-label');

  const loadMoreBtn = document.getElementById('load-more-btn');

  function filterEvents() {

    let visibleCount = 0;
    let shownCount = 0;

    eventCards.forEach(card => {

      const cardCategory = (card.dataset.category || '').toLowerCase();
      const cardMonth = (card.dataset.month || '').toLowerCase();
      const cardStatus = (card.dataset.status || '').toLowerCase();

      const categoryMatch =
        activeCategory === 'all' ||
        cardCategory === activeCategory;

      const monthMatch =
        activeMonth === 'all' ||
        cardMonth === activeMonth;

      const statusMatch =
        cardStatus === activeStatus;

      const isMatch = categoryMatch && monthMatch && statusMatch;

      if (isMatch) {
        visibleCount++;

        if (shownCount < visibleLimit) {
          card.style.display = '';
          shownCount++;
        } else {
          card.style.display = 'none';
        }

      } else {
        card.style.display = 'none';
      }
    });

    // update counter
    if (eventsCount) {
      eventsCount.textContent = visibleCount;
    }

    if (eventsStatusLabel) {
      eventsStatusLabel.textContent = activeStatus;
    }

    // empty state
    if (noEventsMessage) {
      noEventsMessage.style.display = visibleCount === 0 ? 'block' : 'none';
    }

    // load more button logic
    if (loadMoreBtn) {
      if (shownCount >= visibleCount) {
        loadMoreBtn.style.display = 'none';
      } else {
        loadMoreBtn.style.display = 'inline-block';
        loadMoreBtn.textContent = 'Load More Events';
      }
    }
  }

  // CATEGORY FILTER
  categoryButtons.forEach(btn => {
    btn.addEventListener('click', function () {
      categoryButtons.forEach(b => b.classList.remove('active'));
      this.classList.add('active');

      activeCategory = this.dataset.category;

      visibleLimit = 1; // reset on filter change
      filterEvents();
    });
  });

  // MONTH FILTER
  monthButtons.forEach(btn => {
    btn.addEventListener('click', function () {
      monthButtons.forEach(b => b.classList.remove('active'));
      this.classList.add('active');

      activeMonth = this.dataset.month;

      visibleLimit = 1; // reset on filter change
      filterEvents();
    });
  });

  // TAB FILTER (UPCOMING / PAST)
  tabButtons.forEach(btn => {
    btn.addEventListener('click', function () {
      tabButtons.forEach(b => b.classList.remove('active'));
      this.classList.add('active');

      activeStatus = this.dataset.tab;

      visibleLimit = 1; // reset on filter change
      filterEvents();
    });
  });

  // LOAD MORE BUTTON
  if (loadMoreBtn) {
    loadMoreBtn.addEventListener('click', function () {
      visibleLimit += increment;
      filterEvents();
    });
  }

  // initial run
  filterEvents();

});
</script>