<section class="custom-category-grid">
  <div class="custom-category-grid__inner">

    <div class="custom-category-grid__header">
      <p>{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
    </div>

    <div class="custom-category-grid__items">
      {% for block in section.blocks %}
        {% assign collection = block.settings.collection %}

        {% if collection != blank %}
          <a href="{{ collection.url }}" class="custom-category-grid__item" {{ block.shopify_attributes }}>
            
            <div class="custom-category-grid__image">
              {% if block.settings.custom_image != blank %}
                {{ block.settings.custom_image | image_url: width: 700 | image_tag: loading: 'lazy' }}
              {% elsif collection.featured_image != blank %}
                {{ collection.featured_image | image_url: width: 700 | image_tag: loading: 'lazy' }}
              {% else %}
                <span>{{ collection.title }}</span>
              {% endif %}
            </div>

            <h3>{{ collection.title }}</h3>
          </a>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

<style>
  .custom-category-grid {
    background: #f8f6f2;
    padding: 8px 10px;
  }

  .custom-category-grid__inner {
    max-width: 1280px;
    margin: 0 auto;
    background: var(--cream);
    border: 1px solid #d7d1c8;
    border-radius: 4px;
    padding: 30px 38px 34px;
  }

  .custom-category-grid__header {
    text-align: center;
    margin-bottom: 22px;
  }

  .custom-category-grid__header p {
    margin: 0 0 6px;
    color: rgba(46, 61, 52, 0.55);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .custom-category-grid__header h2 {
    margin: 0;
    color: var(--navy);
    font-family: var(--font-heading);
    font-size: 26px;
    line-height: 1.15;
    font-weight: var(--font-weight-bold);
  }

  .custom-category-grid__items {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 26px;
  }

  .custom-category-grid__item {
    text-align: center;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease;
  }

  .custom-category-grid__item:hover {
    transform: translateY(-3px);
  }

  .custom-category-grid__image {
    height: 172px;
    border-radius: 4px;
    background: #d8d5ce;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin-bottom: 10px;
  }

  .custom-category-grid__image span {
    color: rgba(46, 61, 52, 0.45);
    font-family: var(--font-body);
    font-size: 13px;
  }

  .custom-category-grid__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .custom-category-grid__item h3 {
    margin: 0;
    color: var(--navy);
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.2;
    font-weight: var(--font-weight-bold);
  }

  @media screen and (max-width: 900px) {
    .custom-category-grid__inner {
      padding: 28px 20px 30px;
    }

    .custom-category-grid__items {
      grid-template-columns: repeat(2, 1fr);
      gap: 22px;
    }
  }

  @media screen and (max-width: 560px) {
    .custom-category-grid__items {
      grid-template-columns: 1fr;
    }

    .custom-category-grid__header h2 {
      font-size: 24px;
    }
  }
</style>

{% schema %}
{
  "name": "Custom category grid",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "COLLECTIONS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom image override"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom category grid",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}